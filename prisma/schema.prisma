// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}


datasource db {
 provider = "mysql"
 url      = env("DATABASE_URL")
}

enum roleUser {
  admin
  user
}

enum mood{
  baik
  biasa
  buruk
}

enum roleML{
  gold
  exp
  mid
  jungle
  roam
}

model User{
  id String @id @db.VarChar(36) @default(uuid())
  email String @db.VarChar(100) @unique
  username String @db.VarChar(100) @unique
  password String @db.VarChar(100) 
  nama String @db.VarChar(100)
  role roleUser
  game_id String
  server_id String @db.VarChar(4)
  otp String? @db.VarChar(100)
  status Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  absensi Absensi[]
  team Team?

  @@map("users")
}

model Kegiatan{
  id String @id @db.VarChar(36) @default(uuid())
  nama_kegiatan String @db.VarChar(100)
  tanggal_kegiatan DateTime
  jam String @db.VarChar(50)
  absensi Absensi[]
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@map("kegiatan")
}

model Absensi{
  id Int @default(autoincrement()) @id
  user_id String
  kegiatan_id String
  deskripsi String @db.VarChar(1000)
  mood mood
  bukti String @db.VarChar(100)
  createdAt DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  kegiatan Kegiatan @relation(fields: [kegiatan_id], references: [id], onDelete: Cascade)
  @@map("absensi")
}

model Team{
  id Int @id @default(autoincrement())
  nama_tim String @db.VarChar(50)
  user_id String @unique
  role roleML
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@map("teams")
}

